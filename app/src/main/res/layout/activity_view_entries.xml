<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0C1220"
    android:orientation="vertical">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#152037"
        android:padding="20dp"
        android:orientation="vertical"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Health Entries"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track your health journey"
            android:textColor="#B0BEC5"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Stats Cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:weightSum="3">

        <!-- Meal Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#1E3A5F"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍽️"
                android:textSize="20sp"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/tv_meal_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meals"
                android:textColor="#B0BEC5"
                android:textSize="12sp"
                android:layout_gravity="center" />

        </LinearLayout>

        <!-- Insulin Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#1E3A5F"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💉"
                android:textSize="20sp"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/tv_insulin_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Insulin"
                android:textColor="#B0BEC5"
                android:textSize="12sp"
                android:layout_gravity="center" />

        </LinearLayout>

        <!-- Symptom Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#1E3A5F"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginEnd="4dp"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🩺"
                android:textSize="20sp"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/tv_symptom_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Symptoms"
                android:textColor="#B0BEC5"
                android:textSize="12sp"
                android:layout_gravity="center" />

        </LinearLayout>

    </LinearLayout>

    <!-- Entries Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Entries"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="12dp" />

        <!-- Scrollable Entries -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/ll_entries_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Entries will be added programmatically here -->
                <TextView
                    android:id="@+id/tv_no_entries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No entries yet.\nStart tracking your health!"
                    android:textColor="#B0BEC5"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginTop="40dp"
                    android:visibility="visible" />

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</LinearLayout>